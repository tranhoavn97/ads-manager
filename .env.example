# ==========================================================
#  CẤU HÌNH ỨNG DỤNG — KHÔNG commit file .env thật lên git
#  Sao chép file này thành .env rồi điền giá trị của bạn
# ==========================================================

# --- App Meta (lấy tại https://developers.facebook.com/apps) ---
FB_APP_ID=your_app_id_here
FB_APP_SECRET=your_app_secret_here

# Phiên bản Graph API sử dụng
FB_API_VERSION=v20.0

# --- Facebook Login for Business ---
# URL callback phải khớp với cấu hình "Valid OAuth Redirect URIs" trong app
FB_REDIRECT_URI=http://localhost:3000/api/auth/callback

# config_id của cấu hình "Login for Business" (Tùy chọn).
# Nếu để trống, hệ thống sẽ dùng cơ chế xin quyền bằng scope bên dưới.
FB_CONFIG_ID=

# Các quyền cần xin nếu KHÔNG dùng config_id
FB_SCOPES=ads_management,ads_read,pages_show_list,pages_read_engagement,pages_manage_ads,business_management

# --- Bảo mật phiên đăng nhập ---
# Chuỗi ngẫu nhiên dài, dùng để ký cookie phiên (đổi sang giá trị riêng của bạn)
SESSION_SECRET=doi_chuoi_nay_thanh_mot_gia_tri_ngau_nhien_that_dai

# --- Máy chủ ---
PORT=3000

# Đặt true khi chạy production qua HTTPS để cookie phiên được bảo mật
SECURE_COOKIES=false
